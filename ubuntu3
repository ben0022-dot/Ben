<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Ubuntu Fusion Cuisine – Kenyan Fusion Menu</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', system-ui, sans-serif;
    }

    body {
      background: linear-gradient(135deg, #f5e6d3, #e8f4f8);
      background-attachment: fixed;
      min-height: 100vh;
      padding: 0;
      color: #333;
      scroll-behavior: smooth;
    }

    /* HERO with African‑dishes‑style background */
    .hero {
      height: 64vh;
      min-height: 300px;
      background: 
        linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.75)),
        url('https://images.unsplash.com/photo-1546069901-bfea0d5da0b1?ixlib=rb‑4.0.3&auto=format&fit=crop&w=1200&q=80') 
        center/cover no‑repeat;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 1.5rem 1rem;
      text-align: center;
      color: white;
      position: relative;
    }

    .hero h1 {
      font-size: 1.8rem;
      letter-spacing: 0.5px;
      margin-bottom: 0.4rem;
      text-shadow: 1px 1px 4px rgba(0,0,0,0.6);
    }

    .hero p {
      font-size: 1.05rem;
      opacity: 0.9;
      margin-bottom: 0.8rem;
    }

    /* Social icons bar */
    .social-bar {
      display: flex;
      justify-content: center;
      gap: 1.2rem;
      margin-top: 0.8rem;
    }

    .social-bar a {
      color: #fff;
      font-size: 1.3rem;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .social-bar a:hover {
      opacity: 0.8;
      transform: translateY(-2px);
    }

    /* Main content padding */
    .main {
      padding: 1.5rem 1rem 3rem 1rem;
    }

    /* Menu grid (mobile‑first) */
    .menu {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.3rem;
      margin-top: 1rem;
    }

    /* Glass‑morphism card with background image */
    .glass-card {
      background: 
        linear-gradient(rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.25)),
        url('https://images.unsplash.com/photo-1546069901‑dashboard‑burger‑plate.jpg?ixlib=rb‑4.0.3&auto=format&fit=crop&w=800&q=70') 
        center/cover no‑repeat;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.35);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.14);
      padding: 1.4rem 1.2rem;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      max-width: 100%;
      margin: 0 auto;
      color: #333;
    }

    .glass-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 36px rgba(0, 0, 0, 0.18);
    }

    .card-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 0.4rem;
      color: #b36b39;
    }

    .card-desc {
      font-size: 0.92rem;
      color: #555;
      margin-bottom: 0.7rem;
      line-height: 1.45;
    }

    .card-price {
      font-size: 1.1rem;
      font-weight: 600;
      color: #333;
      margin-bottom: 0.9rem;
    }

    .whatsapp-btn {
      display: inline-block;
      background: #25d366;
      color: white;
      padding: 0.6rem 0.9rem;
      border-radius: 8px;
      font-size: 0.95rem;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: background 0.3s ease, transform 0.2s ease;
    }

    .whatsapp-btn:hover {
      background: #128c7e;
      transform: scale(1.03);
    }

    /* Tablet/desktop tweaks */
    @media (min-width: 600px) {
      .menu {
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.6rem;
      }

      .hero {
        height: 60vh;
      }

      .social-bar {
        gap: 1.6rem;
      }
    }

    @media (min-width: 900px) {
      .hero h1 {
        font-size: 2.3rem;
      }

      .hero p {
        font-size: 1.15rem;
      }

      .social-bar {
        font-size: 1.4rem;
      }
    }

    /* Footer */
    footer {
      margin-top: 2rem;
      text-align: center;
      padding: 1rem 0;
      font-size: 0.9rem;
      background: #f9f3e8;
      border-top: 1px solid #e5d6c8;
      color: #555;
    }

    footer a {
      color: #b36b39;
      text-decoration: none;
      margin: 0 0.8rem;
      transition: color 0.3s ease;
    }

    footer a:hover {
      color: #8c4e2c;
      text-decoration: underline;
    }
  </style>
</head>
<body>

